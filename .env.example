# ============================================================
# Duck Store — compose-level configuration
# ============================================================
# Copy to `.env` (setup.sh does this automatically). Values here are
# substituted into docker-compose.yml / docker-compose.dev.yml at
# `docker compose up` time.
#
# This file is for **compose-layer tunables** — things that change how
# containers are wired (host ports, DB name, credentials).
#
# The per-service runtime config (what each app reads via
# process.env / os.Getenv when running on the host) lives in each
# service's own .env file:
#   - warehouse-service/.env
#   - store-service/.env
# In container mode, compose's `environment:` blocks override those
# with in-cluster URLs (mongo, warehouse, store as service names).

# ---------- host ports ----------
# Change these if they conflict with something on your machine.
# Internal container ports stay fixed — services contract on them.
WAREHOUSE_HOST_PORT=4001
STORE_HOST_PORT=4002
MONGO_HOST_PORT=27017
FRONTEND_HOST_PORT=5173

# ---------- mongo ----------
MONGO_DB=duckstore

# ---------- runtime ----------
NODE_ENV=development

# ---------- future secrets ----------
# Uncomment + fill in when/if we add auth. These propagate through
# compose `environment:` overrides. Never commit a real .env with
# values filled in.
# MONGO_USER=duckstore
# MONGO_PASSWORD=
